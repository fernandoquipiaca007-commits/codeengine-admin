# =========================================================
# codeengine-admin - .gitignore
# =========================================================
node_modules/
dist/
build/
out/
.vite/
.turbo/
coverage/

# Environment
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp

# TypeScript / ESLint
*.tsbuildinfo
.eslintcache

# Testing
coverage/
.nyc_output/

# Sensitive
*.pem
*.key
secrets.json
